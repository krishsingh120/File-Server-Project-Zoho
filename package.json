{
  "name": "file-server-zoho",
  "version": "1.0.0",
  "description": "Cross-platform GUI-based File Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --testEnvironment=node --forceExit",
    "test:watch": "jest --testEnvironment=node --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "forceExit": true,
    "clearMocks": true,
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ]
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "rate-limit-redis": "^4.3.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "uuid": "^8.3.2",
    "winston": "^3.19.0"
  }
}
